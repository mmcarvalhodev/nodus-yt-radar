{
  "manifest_version": 3,
  "name": "NODUS YT Radar",
  "version": "0.2.1",
  "description": "Real-time trending rank, viral score and momentum analytics for the YouTube video you're watching, by country.",
  "permissions": ["storage", "tabs", "sidePanel"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://worker-yt-radar.mmcarvalho-dev.workers.dev"
  },
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://worker-yt-radar.mmcarvalho-dev.workers.dev/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NODUS YT Radar"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
